FROM node:20-alpine AS builder

WORKDIR /app

# Build context is monorepo root (same shape as admin-ui).
COPY package.json package-lock.json ./
COPY admin-ui/package.json ./admin-ui/
COPY portal-ui/package.json ./portal-ui/

RUN npm install --include=dev

COPY portal-ui ./portal-ui

ARG BACKEND_URL=http://backend:8000
ENV BACKEND_URL=${BACKEND_URL}
ENV NEXT_TELEMETRY_DISABLED=1

WORKDIR /app/portal-ui
RUN npm run build

FROM node:20-alpine AS runner

WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=builder /app/portal-ui/.next ./.next
COPY --from=builder /app/portal-ui/node_modules ./node_modules
COPY --from=builder /app/portal-ui/package.json ./
COPY --from=builder /app/portal-ui/next.config.js ./

EXPOSE 3001
CMD ["npm", "run", "start", "--", "-H", "0.0.0.0", "-p", "3001"]
