<views>

  <!-- Lead (deal) list view -->
  <view name="crm.lead.list" model="crm.lead" type="list" priority="16">
    <list>
      <field name="name" string="Deal"/>
      <field name="organization_id" string="Organization" widget="many2one"/>
      <field name="person_id" string="Contact" widget="many2one"/>
      <field name="stage_id" string="Stage" widget="many2one"/>
      <field name="expected_revenue" string="Expected Revenue" widget="monetary"/>
      <field name="probability" string="Probability" widget="percentage"/>
      <field name="expected_close_date" string="Expected Close"/>
      <field name="assigned_user_id" string="Salesperson" widget="many2one"/>
      <field name="lifecycle_stage" string="Lifecycle"/>
    </list>
  </view>

  <!-- Lead kanban view -->
  <view name="crm.lead.kanban" model="crm.lead" type="kanban" priority="16">
    <kanban group_by="stage_id" quick_create="1">
      <field name="name"/>
      <field name="organization_id"/>
      <field name="person_id"/>
      <field name="expected_revenue"/>
      <field name="probability"/>
      <field name="assigned_user_id"/>
      <field name="stage_entered_at"/>
      <field name="last_activity_at"/>
      <templates>
        <t t-name="kanban-card">
          <div class="kanban-card">
            <strong><field name="name"/></strong>
            <div><field name="organization_id"/></div>
            <div><field name="expected_revenue"/> · <field name="probability"/>%</div>
            <footer>
              <field name="assigned_user_id" widget="avatar"/>
            </footer>
          </div>
        </t>
      </templates>
    </kanban>
  </view>

  <!-- Lead form view -->
  <view name="crm.lead.form" model="crm.lead" type="form" priority="16">
    <form>
      <header>
        <field name="stage_id" widget="statusbar"/>
      </header>
      <sheet>
        <group string="Deal">
          <field name="name" required="1" string="Title"/>
          <field name="organization_id" string="Organization" widget="many2one"/>
          <field name="person_id" string="Contact" widget="many2one"/>
          <field name="pipeline_id" string="Pipeline" widget="many2one"/>
          <field name="assigned_user_id" string="Salesperson" widget="many2one"/>
          <field name="assigned_team_id" string="Team" widget="many2one"/>
        </group>
        <group string="Forecast">
          <field name="expected_revenue" string="Expected Revenue" widget="monetary"/>
          <field name="probability" string="Probability" widget="percentage"/>
          <field name="expected_close_date" string="Expected Close"/>
        </group>
        <group string="Pipeline Health">
          <field name="stage_entered_at" string="Stage Entered" readonly="1"/>
          <field name="last_activity_at" string="Last Activity" readonly="1"/>
          <field name="lost_reason" string="Lost Reason"/>
        </group>
        <group string="Lifecycle &amp; Attribution">
          <field name="lifecycle_stage" string="Lifecycle Stage"/>
          <field name="utm_source" string="UTM Source"/>
          <field name="utm_medium" string="UTM Medium"/>
          <field name="utm_campaign" string="UTM Campaign"/>
          <field name="utm_content" string="UTM Content"/>
          <field name="utm_term" string="UTM Term"/>
        </group>
        <notebook>
          <page string="Description">
            <field name="description" widget="html" nolabel="1"/>
          </page>
          <page string="Tags">
            <field name="tags" widget="tags" nolabel="1"/>
          </page>
        </notebook>
      </sheet>
    </form>
  </view>

  <!-- Lead graph view — revenue by stage -->
  <view name="crm.lead.graph" model="crm.lead" type="graph" priority="16">
    <graph string="Expected revenue" type="bar">
      <field name="stage_id" type="row"/>
      <field name="expected_revenue" type="measure"/>
    </graph>
  </view>

  <!-- Lead search view -->
  <view name="crm.lead.search" model="crm.lead" type="search" priority="16">
    <search>
      <field name="name" string="Deal"/>
      <field name="organization_id" string="Organization"/>
      <field name="person_id" string="Contact"/>
      <field name="assigned_user_id" string="Salesperson"/>
      <field name="lifecycle_stage" string="Lifecycle"/>
      <filter name="my_leads" string="My Deals" domain="[('assigned_user_id', '=', 'current_user')]"/>
      <filter name="lifecycle_mql" string="MQL" domain="[('lifecycle_stage', '=', 'mql')]"/>
      <filter name="lifecycle_sql" string="SQL" domain="[('lifecycle_stage', '=', 'sql')]"/>
      <filter name="lifecycle_opportunity" string="Opportunity" domain="[('lifecycle_stage', '=', 'opportunity')]"/>
      <filter name="lifecycle_customer" string="Customer" domain="[('lifecycle_stage', '=', 'customer')]"/>
      <filter name="won" string="Won" domain="[('stage_id.is_won', '=', True)]"/>
      <filter name="lost" string="Lost" domain="[('stage_id.is_lost', '=', True)]"/>
      <filter name="rotting" string="Rotting" domain="[('stage_id.rotting_days', '!=', False), ('stage_id.is_won', '=', False), ('stage_id.is_lost', '=', False)]"/>
      <group expand="0" string="Group By">
        <filter name="by_stage" string="Stage" context="{'group_by': 'stage_id'}"/>
        <filter name="by_pipeline" string="Pipeline" context="{'group_by': 'pipeline_id'}"/>
        <filter name="by_salesperson" string="Salesperson" context="{'group_by': 'assigned_user_id'}"/>
        <filter name="by_organization" string="Organization" context="{'group_by': 'organization_id'}"/>
      </group>
    </search>
  </view>

</views>
