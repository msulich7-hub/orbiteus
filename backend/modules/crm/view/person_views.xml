<views>

  <!-- Person (contact) list view -->
  <view name="crm.person.list" model="crm.person" type="list" priority="16">
    <list>
      <field name="name" string="Name"/>
      <field name="email" string="Email"/>
      <field name="phone" string="Phone"/>
      <field name="kind" string="Kind" widget="badge"/>
      <field name="organization_id" string="Organization" widget="many2one"/>
      <field name="city" string="City"/>
      <field name="assigned_user_id" string="Assigned To" widget="many2one"/>
    </list>
  </view>

  <!-- Person form view -->
  <view name="crm.person.form" model="crm.person" type="form" priority="16">
    <form>
      <sheet>
        <group string="Contact">
          <field name="name" required="1" string="Name"/>
          <field name="email" string="Email"/>
          <field name="phone" string="Phone"/>
          <field name="mobile" string="Mobile"/>
          <field name="kind" string="Kind"/>
          <field name="is_company" string="Is Company"/>
        </group>
        <group string="Organization">
          <field name="organization_id" string="Organization" widget="many2one"/>
          <field name="vat" string="VAT"/>
          <field name="website" string="Website"/>
        </group>
        <group string="Address">
          <field name="street" string="Street"/>
          <field name="city" string="City"/>
          <field name="country_code" string="Country"/>
        </group>
        <group string="Assignment">
          <field name="assigned_user_id" string="Assigned To" widget="many2one"/>
          <field name="assigned_team_id" string="Team" widget="many2one"/>
          <field name="source" string="Source"/>
        </group>
        <notebook>
          <page string="Tags">
            <field name="tags" widget="tags" nolabel="1"/>
          </page>
          <page string="Notes">
            <field name="notes" widget="html" nolabel="1"/>
          </page>
        </notebook>
      </sheet>
    </form>
  </view>

  <!-- Person search view -->
  <view name="crm.person.search" model="crm.person" type="search" priority="16">
    <search>
      <field name="name" string="Name"/>
      <field name="email" string="Email"/>
      <field name="phone" string="Phone"/>
      <field name="organization_id" string="Organization"/>
      <filter name="contacts" string="Contacts" domain="[('kind', '=', 'contact')]"/>
      <filter name="leads" string="Leads" domain="[('kind', '=', 'lead')]"/>
      <filter name="customers" string="Customers" domain="[('kind', '=', 'customer')]"/>
      <filter name="my_contacts" string="My Contacts" domain="[('assigned_user_id', '=', 'current_user')]"/>
      <group expand="0" string="Group By">
        <filter name="by_kind" string="Kind" context="{'group_by': 'kind'}"/>
        <filter name="by_organization" string="Organization" context="{'group_by': 'organization_id'}"/>
        <filter name="by_assigned" string="Assigned To" context="{'group_by': 'assigned_user_id'}"/>
      </group>
    </search>
  </view>

</views>
