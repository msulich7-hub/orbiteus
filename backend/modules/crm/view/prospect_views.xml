<views>

  <!-- Prospect inbox list view -->
  <view name="crm.prospect.list" model="crm.prospect" type="list" priority="16">
    <list>
      <field name="name" string="Prospect"/>
      <field name="organization_id" string="Organization" widget="many2one"/>
      <field name="person_id" string="Contact" widget="many2one"/>
      <field name="temperature" string="Temperature" widget="badge"/>
      <field name="source" string="Source"/>
      <field name="lifecycle_stage" string="Lifecycle"/>
      <field name="assigned_user_id" string="Assigned To" widget="many2one"/>
      <field name="is_converted" string="Converted"/>
    </list>
  </view>

  <!-- Prospect form — convert-friendly fields -->
  <view name="crm.prospect.form" model="crm.prospect" type="form" priority="16">
    <form>
      <header>
        <field name="is_converted" widget="boolean_toggle" readonly="1"/>
      </header>
      <sheet>
        <group string="Prospect">
          <field name="name" required="1" string="Title"/>
          <field name="organization_id" string="Organization" widget="many2one"/>
          <field name="person_id" string="Contact" widget="many2one"/>
          <field name="assigned_user_id" string="Assigned To" widget="many2one"/>
        </group>
        <group string="Qualification">
          <field name="source" string="Source"/>
          <field name="temperature" string="Temperature"/>
          <field name="lifecycle_stage" string="Lifecycle Stage"/>
          <field name="converted_lead_id" string="Converted Deal" widget="many2one" readonly="1"/>
        </group>
        <group string="Attribution">
          <field name="utm_source" string="UTM Source"/>
          <field name="utm_medium" string="UTM Medium"/>
          <field name="utm_campaign" string="UTM Campaign"/>
          <field name="utm_content" string="UTM Content"/>
          <field name="utm_term" string="UTM Term"/>
        </group>
        <notebook>
          <page string="Notes">
            <field name="notes" widget="html" nolabel="1"/>
          </page>
        </notebook>
      </sheet>
    </form>
  </view>

  <!-- Prospect search view -->
  <view name="crm.prospect.search" model="crm.prospect" type="search" priority="16">
    <search>
      <field name="name" string="Prospect"/>
      <field name="organization_id" string="Organization"/>
      <field name="person_id" string="Contact"/>
      <field name="source" string="Source"/>
      <filter name="inbox" string="Inbox" domain="[('is_converted', '=', False)]"/>
      <filter name="converted" string="Converted" domain="[('is_converted', '=', True)]"/>
      <filter name="hot" string="Hot" domain="[('temperature', '=', 'hot')]"/>
      <filter name="warm" string="Warm" domain="[('temperature', '=', 'warm')]"/>
      <filter name="cold" string="Cold" domain="[('temperature', '=', 'cold')]"/>
      <filter name="my_prospects" string="My Prospects" domain="[('assigned_user_id', '=', 'current_user')]"/>
      <group expand="0" string="Group By">
        <filter name="by_temperature" string="Temperature" context="{'group_by': 'temperature'}"/>
        <filter name="by_source" string="Source" context="{'group_by': 'source'}"/>
        <filter name="by_assigned" string="Assigned To" context="{'group_by': 'assigned_user_id'}"/>
      </group>
    </search>
  </view>

</views>
