<views>

  <!-- Activity list view -->
  <view name="crm.activity.list" model="crm.activity" type="list" priority="16">
    <list>
      <field name="subject" string="Subject"/>
      <field name="activity_type" string="Type" widget="badge"/>
      <field name="due_date" string="Due Date"/>
      <field name="done" string="Done"/>
      <field name="assigned_user_id" string="Assigned To" widget="many2one"/>
      <field name="res_model" string="Related Model"/>
      <field name="outcome" string="Outcome"/>
    </list>
  </view>

  <!-- Activity form view -->
  <view name="crm.activity.form" model="crm.activity" type="form" priority="16">
    <form>
      <header>
        <field name="done" widget="boolean_toggle"/>
      </header>
      <sheet>
        <group string="Activity">
          <field name="subject" required="1" string="Subject"/>
          <field name="activity_type" string="Type"/>
          <field name="due_date" string="Due Date"/>
          <field name="assigned_user_id" string="Assigned To" widget="many2one"/>
        </group>
        <group string="Completion">
          <field name="done_at" string="Done At" readonly="1"/>
          <field name="duration_minutes" string="Duration (min)"/>
          <field name="outcome" string="Outcome"/>
        </group>
        <group string="Related Record">
          <field name="res_model" string="Model"/>
          <field name="res_id" string="Record"/>
        </group>
        <notebook>
          <page string="Notes">
            <field name="notes" widget="html" nolabel="1"/>
          </page>
        </notebook>
      </sheet>
    </form>
  </view>

  <!-- Activity search view -->
  <view name="crm.activity.search" model="crm.activity" type="search" priority="16">
    <search>
      <field name="subject" string="Subject"/>
      <field name="activity_type" string="Type"/>
      <field name="assigned_user_id" string="Assigned To"/>
      <filter name="open" string="Open" domain="[('done', '=', False)]"/>
      <filter name="done" string="Done" domain="[('done', '=', True)]"/>
      <filter name="my_activities" string="My Activities" domain="[('assigned_user_id', '=', 'current_user')]"/>
      <filter name="calls" string="Calls" domain="[('activity_type', '=', 'call')]"/>
      <filter name="meetings" string="Meetings" domain="[('activity_type', '=', 'meeting')]"/>
      <filter name="tasks" string="Tasks" domain="[('activity_type', '=', 'task')]"/>
      <group expand="0" string="Group By">
        <filter name="by_type" string="Type" context="{'group_by': 'activity_type'}"/>
        <filter name="by_assigned" string="Assigned To" context="{'group_by': 'assigned_user_id'}"/>
        <filter name="by_due_date" string="Due Date" context="{'group_by': 'due_date'}"/>
      </group>
    </search>
  </view>

</views>
