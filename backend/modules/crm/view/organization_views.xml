<views>

  <!-- Organization list view -->
  <view name="crm.organization.list" model="crm.organization" type="list" priority="16">
    <list>
      <field name="name" string="Organization"/>
      <field name="vat" string="VAT"/>
      <field name="industry" string="Industry"/>
      <field name="city" string="City"/>
      <field name="country_code" string="Country"/>
      <field name="assigned_user_id" string="Assigned To" widget="many2one"/>
    </list>
  </view>

  <!-- Organization form view -->
  <view name="crm.organization.form" model="crm.organization" type="form" priority="16">
    <form>
      <sheet>
        <group string="Organization">
          <field name="name" required="1" string="Name"/>
          <field name="vat" string="VAT"/>
          <field name="website" string="Website"/>
          <field name="industry" string="Industry"/>
        </group>
        <group string="Address">
          <field name="street" string="Street"/>
          <field name="city" string="City"/>
          <field name="country_code" string="Country"/>
        </group>
        <group string="Assignment">
          <field name="assigned_user_id" string="Assigned To" widget="many2one"/>
          <field name="assigned_team_id" string="Team" widget="many2one"/>
        </group>
        <notebook>
          <page string="Tags">
            <field name="tags" widget="tags" nolabel="1"/>
          </page>
          <page string="Notes">
            <field name="notes" widget="html" nolabel="1"/>
          </page>
        </notebook>
      </sheet>
    </form>
  </view>

  <!-- Organization search view -->
  <view name="crm.organization.search" model="crm.organization" type="search" priority="16">
    <search>
      <field name="name" string="Organization"/>
      <field name="vat" string="VAT"/>
      <field name="city" string="City"/>
      <field name="industry" string="Industry"/>
      <filter name="my_organizations" string="My Organizations" domain="[('assigned_user_id', '=', 'current_user')]"/>
      <group expand="0" string="Group By">
        <filter name="by_industry" string="Industry" context="{'group_by': 'industry'}"/>
        <filter name="by_city" string="City" context="{'group_by': 'city'}"/>
        <filter name="by_assigned" string="Assigned To" context="{'group_by': 'assigned_user_id'}"/>
      </group>
    </search>
  </view>

</views>
