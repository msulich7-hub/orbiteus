<views>

  <view name="shipping.shipment.list" model="shipping.shipment" type="list" priority="16">
    <list>
      <field name="reference" string="Referencja"/>
      <field name="carrier_code" string="Kurier" widget="badge"/>
      <field name="state" string="Status" widget="badge"/>
      <field name="tracking_number" string="Waybill"/>
      <field name="order_id" string="Zamówienie" widget="many2one"/>
      <field name="weight_kg" string="Waga kg"/>
      <field name="is_pallet" string="Paleta"/>
    </list>
  </view>

  <view name="shipping.shipment.form" model="shipping.shipment" type="form" priority="16">
    <form>
      <header>
        <field name="state" widget="statusbar"/>
        <field name="carrier_code" widget="badge"/>
      </header>
      <sheet>
        <group string="Przesyłka">
          <field name="reference" string="Referencja"/>
          <field name="order_id" string="Zamówienie" widget="many2one"/>
          <field name="carrier_code" string="Kurier"/>
          <field name="tracking_number" string="Numer listu"/>
          <field name="weight_kg" string="Waga (kg)"/>
          <field name="is_pallet" string="Paleta"/>
          <field name="is_locker" string="Paczkomat"/>
          <field name="forward_agent_id" string="Agent IFS"/>
        </group>
        <group string="Błąd integracji">
          <field name="error_message" string="Komunikat"/>
        </group>
      </sheet>
    </form>
  </view>

</views>
