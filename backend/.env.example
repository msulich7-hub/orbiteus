# Orbiteus Backend – environment variables
# Copy to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://orbiteus:orbiteus@localhost:5432/orbiteus
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (cache, rate limit, JTI revocation, Pub/Sub, Celery broker).
REDIS_URL=redis://localhost:6379/0

# AI provider key encryption (Fernet, ADR-0004). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AI_SECRET_KEY=change-me-with-fernet-key

ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
ALLOW_PUBLIC_REGISTRATION=true
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin1234
# Default tenant created on first startup; the bootstrap admin is bound
# to this tenant so AI BYOK, share-link issue, audit attribution and the
# rest of the multi-tenancy surface work out of the box.
BOOTSTRAP_ADMIN_TENANT_NAME=Orbiteus
BOOTSTRAP_ADMIN_TENANT_SLUG=orbiteus
