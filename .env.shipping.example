# DPD_SENDER_ADDRESS=ul. Bestwińska 143
# DPD_SENDER_CITY=Bielsko-Biała
# DPD_SENDER_POSTAL_CODE=43346
# DPD_SENDER_COUNTRY=PL
# DPD_SENDER_PHONE=
# DPD_SENDER_EMAIL=
# SHIPPING_DPD_NATIVE=1

# ─── InPost ───
# INPOST_API_TOKEN=
# INPOST_ORGANIZATION_ID=
# INPOST_ENV=sandbox

# ─── Kanał B (optional) ───
# IFS_RELAY_BASE_URL=http://127.0.0.1:3130
# IFS_RELAY_SERVER_API_KEY=

# ─── IFS inbound webhook (Oracle SECONDARY → crm-engine) ───
# POST http://<host>:<port>/api/ifs/webhook/shipment
# Mercato PRIMARY unchanged (:3100). Set SECONDARY URL in MS_INTEGRATION_API on SID:TEST.
IFS_WEBHOOK_ENABLED=1
# IFS_WEBHOOK_SECRET=
# IFS_WEBHOOK_ALLOWLIST=10.10.99.42,10.10.99.60
# IFS_AUTO_DISPATCH=0
