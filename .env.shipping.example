# Shipping / carrier env — copied from mercato/modules/mercato-shipping-hub/.env.example
# Sync from Mercato: .\scripts\sync-carrier-env-from-mercato.ps1
# Do not commit secrets — append to crm-engine/.env on VM or local Docker.

# ─── Logistics routing (mercato-logistics-hub) ───
LOGISTICS_PALLET_CARRIER=geodis
LOGISTICS_HEAVY_KG=100
LOGISTICS_LIGHT_MAX_KG=30
LOGISTICS_RESPECT_IFS_AGENT=1

# ─── DSV / DB Schenker ───
# DSV_ACCESS_KEY=
# DSV_GROUP_ID=
# DSV_USER_ID=
# DSV_ENV=test
# DSV_ENDPOINT=
# DSV_INCOTERM=DAP
# DSV_PRODUCT_CODE=43
# DSV_VAT_NO=5482614481
# DSV_DEFAULT_LOCATION=bielsko
# DSV_SENDER_COUNTRY=PL
# DSV_SENDER_PHONE=
# DSV_SENDER_EMAIL=
# DSV_INTERNATIONAL_GROUP_ID=2170537
# SHIPPING_DSV_NATIVE=1

# ─── Geodis ───
# GEODIS_SHIPPER_ID=
# GEODIS_PASSWORD=

# ─── DPD Poland ───
# DPD_LOGIN=
# DPD_PASSWORD=
# DPD_MASTER_FID=
# DPD_FID=
# DPD_ENV=test
# DPD_ENDPOINT=
# DPD_SOAP_URL=
# DPD_LABEL_FORMAT=PDF
# DPD_SENDER_COMPANY=MDM NT SP. Z O.O.
