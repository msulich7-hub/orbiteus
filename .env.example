# Copy to .env and adjust values
# .env is gitignored — never commit secrets

# Database (used by docker-compose automatically)
POSTGRES_USER=orbiteus
POSTGRES_PASSWORD=orbiteus
POSTGRES_DB=orbiteus

# Backend
DATABASE_URL=postgresql+asyncpg://orbiteus:orbiteus@localhost:5432/orbiteus
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
ALLOW_PUBLIC_REGISTRATION=true
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin1234
# Default tenant created on first startup; the bootstrap admin is bound to
# this tenant so AI BYOK, share-link issue, audit attribution and the rest
# of the multi-tenancy surface work out of the box.
BOOTSTRAP_ADMIN_TENANT_NAME=Orbiteus
BOOTSTRAP_ADMIN_TENANT_SLUG=orbiteus

# Frontend (Next.js) — only needed when running outside Docker
# BACKEND_URL=http://localhost:8000

# Optional: AI reranking (leave empty to skip LLM calls)
# ANTHROPIC_API_KEY=sk-ant-...
