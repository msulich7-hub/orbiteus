# Copy to repo root as `.env.prod`. NEVER commit the filled file.
# Generate strong values:
#   POSTGRES_PASSWORD=$(openssl rand -hex 24)
#   SECRET_KEY=$(openssl rand -hex 32)
#   AI_SECRET_KEY=$(python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")

POSTGRES_PASSWORD=please-rotate-me
SECRET_KEY=please-rotate-me-32-bytes-hex
AI_SECRET_KEY=please-generate-a-fernet-key

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=please-rotate-on-first-login

ALLOW_PUBLIC_REGISTRATION=true
CORS_ORIGINS=["https://app.example.com"]

# Gunicorn tuning. Default 4 workers; for prod set to 2*vCPU+1.
GUNICORN_WORKERS=4

# Optional: nginx host port mapping. Defaults 80 / 443.
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
